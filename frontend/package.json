{
  "name": "vagrantfile-generator-frontend",
  "version": "0.1.0",
  "license": "MIT",
  "description": "Frontend for Vagrantfile Generator",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "test:e2e": "playwright test",
    "test:e2e:dashboard": "playwright test tests/e2e/projects-dashboard.spec.ts",
    "test:e2e:report": "playwright show-report",
    "tailwind": "tailwindcss -i ./src/styles/input.css -o ./src/styles/output.css",
    "tailwind:watch": "tailwindcss -i ./src/styles/input.css -o ./src/styles/output.css --watch"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/forms": "^0.5.0",
    "autoprefixer": "^10.4.0",
    "postcss": "^8.4.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^6.0.3",
    "vite": "^5.0.0"
  },
  "dependencies": {
    "alpinejs": "^3.13.0",
    "marked": "^11.0.0"
  }
}
