# Deployment Configuration
DEPLOYMENT_MODE=self-hosted  # Options: self-hosted, public

# JWT Session Configuration
JWT_SECRET=your-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# Email OTP Configuration (required only for public mode)
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=your-mailgun-domain.com
MAILGUN_FROM_EMAIL=noreply@your-domain.com

# OIDC Provider Configuration (optional, for public mode)
# Google
OIDC_GOOGLE_CLIENT_ID=your-google-client-id
OIDC_GOOGLE_CLIENT_SECRET=your-google-client-secret
OIDC_GOOGLE_REDIRECT_URI=http://localhost:8000/api/auth/callback/google

# GitHub
OIDC_GITHUB_CLIENT_ID=your-github-client-id
OIDC_GITHUB_CLIENT_SECRET=your-github-client-secret
OIDC_GITHUB_REDIRECT_URI=http://localhost:8000/api/auth/callback/github

# GitLab
OIDC_GITLAB_CLIENT_ID=your-gitlab-client-id
OIDC_GITLAB_CLIENT_SECRET=your-gitlab-client-secret
OIDC_GITLAB_REDIRECT_URI=http://localhost:8000/api/auth/callback/gitlab

# Rate Limiting Configuration
OTP_RATE_LIMIT_MAX_REQUESTS=5
OTP_RATE_LIMIT_WINDOW_HOURS=1

# OTP Configuration
OTP_LENGTH=6
OTP_EXPIRATION_MINUTES=15
OTP_MAX_ATTEMPTS=3

# Application Configuration
API_HOST=0.0.0.0
API_PORT=8000
BASE_URL=http://localhost:8000
FRONTEND_URL=http://localhost:8080
LOG_LEVEL=INFO

